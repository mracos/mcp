#!/usr/bin/env bash
# mcp - Manage MCP servers
#
# USAGE:
#   mcp list                     List all configured MCP servers
#   mcp add <name> <url>         Add HTTP MCP server
#   mcp add <name> -- <cmd>      Add stdio MCP server
#   mcp remove <name>            Remove an MCP server
#   mcp edit                     Open mcp-servers.json in $EDITOR
#   mcp apply                    Sync into ~/.claude.json and ~/.codex/config.toml
#   mcp show <name>              Show server config as JSON
#   mcp daemon [start|stop|status|logs]  Manage MCP proxy daemons
#   mcp logs [name]              Tail daemon logs
#
# FLAGS:
#   --env KEY=VALUE              Add env var to server (repeatable, add only)
#   --no-apply                   Skip auto-apply after add/remove
#   -h, --help                   Show help

set -euo pipefail

# Resolve symlinks to find real script location
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$REPO_ROOT/lib"
source "$LIB_DIR/lib-cli.bash"

cmd="${1:-}"
cli_is_help "$cmd" && usage 0
[[ -z "$cmd" ]] && usage 0

# Aliases
case "$cmd" in
  ls) cmd="list" ;;
  rm) cmd="remove" ;;
  sync) cmd="apply" ;;
esac

cli_exec_subcommand "$LIB_DIR" "mcp-" "$cmd" "$@" || {
  echo "Unknown command: $cmd"
  usage
}
