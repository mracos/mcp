{
  "notion": {
    "type": "http",
    "url": "https://mcp.notion.com/mcp"
  },
  "readwise": {
    "type": "stdio-http-proxy",
    "command": "npx",
    "args": ["-y", "@readwise/readwise-mcp"],
    "env": {
      "ACCESS_TOKEN": "${READWISE_ACCESS_TOKEN}"
    },
    "port": 8081
  },
  "linear-server": {
    "type": "http",
    "url": "https://mcp.linear.app/mcp"
  },
  "granola": {
    "type": "stdio-http-proxy",
    "command": "bunx",
    "args": ["--bun", "github:btn0s/granola-mcp/src/index.ts"],
    "port": 8083
  }
}
